# ============================================================
# Copiar a .env.local y rellenar con los valores correspondientes
#
# Modos de entorno (npm run dev siempre):
#   Supabase local   →  URL=http://127.0.0.1:54321 (npm run supabase:start)
#   Supabase remoto  →  URL=https://xxx.supabase.co
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
# Remoto:  obtener en https://app.supabase.com/project/_/settings/api
# Local:   obtener ejecutando: npm run supabase:status
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Email ─────────────────────────────────────────────────────
# Obtener en: https://resend.com/api-keys
# Para local se puede dejar como dummy
RESEND_API_KEY=re_dummy_local

# ── App ───────────────────────────────────────────────────────
# En local: http://localhost:3000
# En Vercel: configurar con el dominio real de producción
NEXT_PUBLIC_SITE_URL=http://localhost:3000
